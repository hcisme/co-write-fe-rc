{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2024",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "checkJs": false,
    "experimentalDecorators": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "**/node_modules/*"
  ]
}